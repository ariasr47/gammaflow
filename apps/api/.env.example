# Convexa backend — environment TEMPLATE (documentation only).
# ----------------------------------------------------------------------------
# Copy to apps/api/.env and fill in YOUR values:   cp .env.example .env
# This file contains NO secret values — only the var NAMES + what they do. It is
# committed as documentation; the real .env is gitignored and is NEVER baked into
# any image (docker-compose injects it at runtime via env_file).
#
# Every var below is OPTIONAL at boot — absent values degrade gracefully (no
# crash): no MASSIVE_API_KEY -> provider errors per existing behavior; no
# ANTHROPIC_API_KEY -> in-app AI rec `unavailable:no_key` (manual export floor
# still works); no Google creds -> "Continue with Google" present-but-disabled;
# no signing/encryption key -> ephemeral per-process key (resets on restart).
# Defaults shown in (parentheses) are the code defaults — leave a line blank/unset
# to take the default; do NOT put a value here.
# ----------------------------------------------------------------------------

# --- Market data vendor (Massive / Polygon-style) ---
MASSIVE_API_KEY=
DATA_FEED=                       # realtime | delayed
DATA_PROVIDER=                   # provider selector (default: massive)

# --- Polling / freshness / gate / live / dark-pool / vol-OI / tiers ---
CACHE_TTL_SECONDS=               # (60)  in-memory bundle cache TTL
STALE_AFTER_SECONDS=             # (120) snapshot age beyond which data is flagged stale
GATE_SCORE=                      # (50)  opportunity_score at/above which the AI gate opens
FLOW_WINDOW_SECONDS=             # (300) rolling net-flow window
LIVE_THROTTLE_SECONDS=           # (1.5) SSE broadcast cadence
CHAIN_REFRESH_SECONDS=           # (120) live chain re-fetch cadence
CHAIN_PREWARM_MAX_AGE_SECONDS=   # chain pre-warm freshness budget (clamped <= min(refresh, stale))
INCLUDE_DARK_POOL=               # (true) include off-exchange context by default
DARKPOOL_LOOKBACK_SECONDS=       # (3600) bounded off-exchange window
BLOCK_MIN_SHARES=                # (5000) institutional-size threshold for a block print
VOL_OI_UNUSUAL_THRESHOLD=        # (1.0)  vol/OI ratio above which a strike reads "unusual"
TIER_WATCH_SCORE=                # (25)   opportunity-tier band: watch
TIER_ACTIONABLE_SCORE=           # (=GATE_SCORE) band: actionable
TIER_PRIME_SCORE=                # (75)   band: prime (also requires ai_eval.ready)

# --- Backend observability (operator-only; off => bundle byte-identical) ---
OBSERVABILITY_ENABLED=           # (true)
METRICS_WINDOW_SIZE=             # (500)  rolling-window request count
METRICS_RECENT_TRACES=           # (25)

# --- In-app AI recommendations (server-side key; never in the browser) ---
ANTHROPIC_API_KEY=
AI_REC_MODEL=                    # latest Claude
AI_REC_COOLDOWN_SECONDS=         # (60)
AI_REC_DAILY_CAP=                # (50)   global shared-key daily cap
AI_REC_TIMEOUT_SECONDS=          # (60)
AI_REC_IN_APP_ENABLED=           # (true)
AI_REC_STUB=                     # (off)  stub LLM provider for keyless/no-cost verification

# --- User accounts (auth + sessions) ---
ACCOUNT_STORE=                   # (memory) store backend; in-memory SQLite resets on restart
AUTH_SESSION_SIGNING_KEY=        # server-side HMAC key for the session cookie (absent => ephemeral per-process)
GOOGLE_CLIENT_ID=                # absent => "Continue with Google" present-but-disabled
GOOGLE_CLIENT_SECRET=            # server-side only; never reaches the browser
GOOGLE_REDIRECT_URI=

# --- Bring-your-own AI key (per-user encrypted Anthropic key) ---
AI_KEY_ENCRYPTION_KEY=           # server-side Fernet key (absent => ephemeral per-process; stored keys reset on restart)
AI_REC_ADMIN_EMAILS=             # comma-separated admin allowlist that gets the shared-key free allowance
AI_REC_ADMIN_FREE_DAILY=         # (3) per-admin daily free allowance on the shared key
