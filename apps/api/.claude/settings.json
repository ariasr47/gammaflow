{
  "permissions": {
    "allow": [
      "mcp__Claude_Preview__preview_screenshot",
      "mcp__Claude_Preview__preview_console_logs"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".venv/Scripts/python.exe .claude/tools/path_guard.py",
            "statusMessage": "path-guard: lane fence (system-4b)"
          }
        ]
      }
    ]
  }
}
