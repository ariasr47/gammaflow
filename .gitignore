# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc

# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

.nx/cache
.nx/workspace-data
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# Non-Claude AI-assistant scaffolding (Nx-generated). This repo uses Claude Code
# (.claude/) + AGENTS.md; the per-assistant skill mirrors are unused — ignore so
# `nx` regenerating them doesn't re-add them to the repo.
.gemini/
.cursor/
.codex/
.opencode/
.agents/

.claude/worktrees
.claude/settings.local.json
.nx/polygraph
.nx/self-healing
.nx/migrate-runs
vite.config.*.timestamp*
vitest.config.*.timestamp*
test-output

# Python backend (apps/api) — mirrors apps/api/.gitignore for clarity
apps/api/.venv/
apps/api/.env
apps/api/.env.*
!apps/api/.env.example
apps/api/data/
# Backend per-ticker persist dumps land in ./data when uvicorn is run from the repo root
# (DATA_DIR is cwd-relative); ignore that too. Root-anchored so it can't catch a real source dir.
/data/
apps/api/conf/token.txt
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
